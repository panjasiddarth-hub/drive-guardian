# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# JWT
JWT_SECRET=replace-with-a-long-random-string-256-bits

# Email (Gmail App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Alert emails (comma-separated)
ALERT_EMAIL_RECIPIENTS=admin@yourcompany.com

# Redis (optional – defaults to localhost:6379)
REDIS_URL=redis://localhost:6379

# RabbitMQ (optional – defaults to amqp://localhost)
RABBIT_URL=amqp://guest:guest@localhost:5672

# Elasticsearch (optional – defaults to localhost:9200)
ELASTICSEARCH_URL=http://localhost:9200

# Frontend URL for CORS (comma-separated for multiple)
CLIENT_URL=http://localhost:5173

# Prometheus metrics protection key (optional)
METRICS_KEY=replace-with-secret-key

# Server port
PORT=5000
